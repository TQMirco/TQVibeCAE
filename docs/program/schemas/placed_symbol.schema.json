{
  "$defs": {
    "CatalogReference": {
      "description": "Puntatore versionato a una definizione in libreria.",
      "properties": {
        "definition_id": {
          "format": "uuid",
          "title": "Definition Id",
          "type": "string"
        },
        "definition_version": {
          "title": "Definition Version",
          "type": "integer"
        },
        "catalog_kind": {
          "enum": [
            "component",
            "symbol",
            "part",
            "footprint",
            "graphic_cell",
            "graphic_composition"
          ],
          "title": "Catalog Kind",
          "type": "string"
        }
      },
      "required": [
        "definition_id",
        "definition_version",
        "catalog_kind"
      ],
      "title": "CatalogReference",
      "type": "object"
    }
  },
  "description": "Simbolo posizionato sul foglio con link al dominio.",
  "properties": {
    "instance_id": {
      "format": "uuid",
      "title": "Instance Id",
      "type": "string"
    },
    "device_id": {
      "format": "uuid",
      "title": "Device Id",
      "type": "string"
    },
    "fragment_id": {
      "format": "uuid",
      "title": "Fragment Id",
      "type": "string"
    },
    "composition_ref": {
      "$ref": "#/$defs/CatalogReference"
    },
    "x_mm": {
      "default": 0.0,
      "title": "X Mm",
      "type": "number"
    },
    "y_mm": {
      "default": 0.0,
      "title": "Y Mm",
      "type": "number"
    },
    "rotate_deg": {
      "default": 0.0,
      "title": "Rotate Deg",
      "type": "number"
    },
    "designation": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Designation"
    }
  },
  "required": [
    "instance_id",
    "device_id",
    "fragment_id",
    "composition_ref"
  ],
  "title": "PlacedSymbol",
  "type": "object"
}
